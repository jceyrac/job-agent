# Copy this file to .env and fill in your values
# cp .env.example .env

# Groq API (scorer LLM — primary)
GROQ_APIKEY=your_groq_api_key_here

# Google Gemini Flash (scorer fallback — optional but recommended)
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail (email digest sender)
GMAIL_FROM=your.address@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# Notification recipient
NOTIFY_TO=your.destination@email.com

# Joplin Web Clipper (optional — for Joplin export)
JOPLIN_TOKEN=your_joplin_token_here

# RapidAPI (optional — for Wellfound scraper, resets 1st of month, 10 calls/month on BASIC)
X_RAPIDAPI_KEY=your_rapidapi_key_here
